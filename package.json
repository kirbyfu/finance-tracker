{
  "name": "finance-tracker",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:push": "pnpm --filter server db:push",
    "db:studio": "pnpm --filter server db:studio",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
